{
  "name": "bitbucket-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Bitbucket — manage pull requests, branches, and repositories from any MCP client",
  "keywords": [
    "mcp",
    "bitbucket",
    "pull-request",
    "ai",
    "claude",
    "cursor"
  ],
  "homepage": "https://github.com/yourname/bitbucket-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/yourname/bitbucket-mcp-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourname/bitbucket-mcp-server.git"
  },
  "license": "MIT",
  "author": "Hayk Gabrielian",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bitbucket-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky && npm run build"
  },
  "lint-staged": {
    "{src,test}/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": "prettier --write",
    "*.{js,cjs,mjs,json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
